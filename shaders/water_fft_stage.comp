#version 450

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(set=0, binding=0, std430) readonly buffer InputSpectrumBuffer
{
    vec4 inputSpectrumData[];
} inputSpectrumBuffer;

layout(set=1, binding=0, std430) buffer OutputSpectrumBuffer
{
    vec4 outputSpectrumData[];
} outputSpectrumBuffer;

layout(set=2, binding=0) uniform WaterSimulationUniforms
{
    // Keep this block aligned with QuadtreeWaterMeshRenderer::WaterSimulationUniforms.
    uvec4 dispatchParams;
    vec4 timeAndGlobal;
    vec4 cascadeWorldSizesA;
    vec4 cascadeWorldSizesB;
    vec4 cascadeAmplitudesA;
    vec4 cascadeAmplitudesB;
    vec4 cascadeWindDirXA;
    vec4 cascadeWindDirXB;
    vec4 cascadeWindDirZA;
    vec4 cascadeWindDirZB;
    vec4 cascadeWindSpeedsA;
    vec4 cascadeWindSpeedsB;
    vec4 cascadeFetchesA;
    vec4 cascadeFetchesB;
    vec4 cascadeSpreadBlendA;
    vec4 cascadeSpreadBlendB;
    vec4 cascadeSwellA;
    vec4 cascadeSwellB;
    vec4 cascadePeakEnhancementA;
    vec4 cascadePeakEnhancementB;
    vec4 cascadeShortWavesFadeA;
    vec4 cascadeShortWavesFadeB;
    vec4 cascadeChoppinessA;
    vec4 cascadeChoppinessB;
    vec4 foamParams;
    vec4 foamParams2;
    vec4 simulationParams;
} simulation;

const float kTau = 6.28318530718;
const uint kFftResolution = 512u;
const uint kHalfResolution = kFftResolution / 2u;

shared vec4 fftGroupBuffer0[kFftResolution];
shared vec4 fftGroupBuffer1[kFftResolution];

uint spectrumIndex(uint resolution, uint cascadeIndex, uvec2 coord)
{
    return ((cascadeIndex * resolution + coord.y) * resolution) + coord.x;
}

vec2 complexMultiply(vec2 a, vec2 b)
{
    return vec2(
        a.x * b.x - a.y * b.y,
        a.x * b.y + a.y * b.x);
}

void butterflyValues(uint index, uint step, out uvec2 indices, out vec2 twiddle)
{
    uint b = kFftResolution >> (step + 1u);
    uint w = b * (index / b);
    uint i = (w + index) % kFftResolution;
    float angle = kTau * float(w) / float(kFftResolution);
    twiddle = vec2(cos(angle), sin(angle));
    indices = uvec2(i, i + b);
}

vec4 fftValue(uint logicalIndex, bool useBuffer1, uint step)
{
    uvec2 indices;
    vec2 twiddle;
    butterflyValues(logicalIndex, step, indices, twiddle);

    vec4 a = useBuffer1 ? fftGroupBuffer1[indices.x] : fftGroupBuffer0[indices.x];
    vec4 b = useBuffer1 ? fftGroupBuffer1[indices.y] : fftGroupBuffer0[indices.y];
    vec2 bHeight = complexMultiply(twiddle, b.xy);
    vec2 bChop = complexMultiply(twiddle, b.zw);
    return a + vec4(bHeight, bChop);
}

void loadInitialValues(uint cascadeIndex, uint axis, uint lineIndex, uint localIndex)
{
    uint index0 = localIndex;
    uint index1 = localIndex + kHalfResolution;

    uvec2 coord0 = axis == 0u ? uvec2(index0, lineIndex) : uvec2(lineIndex, index0);
    uvec2 coord1 = axis == 0u ? uvec2(index1, lineIndex) : uvec2(lineIndex, index1);

    fftGroupBuffer0[index0] = inputSpectrumBuffer.inputSpectrumData[spectrumIndex(kFftResolution, cascadeIndex, coord0)];
    fftGroupBuffer0[index1] = inputSpectrumBuffer.inputSpectrumData[spectrumIndex(kFftResolution, cascadeIndex, coord1)];
}

void storeFinalValues(uint cascadeIndex, uint axis, uint lineIndex, uint localIndex, bool finalInBuffer1)
{
    uint index0 = localIndex;
    uint index1 = localIndex + kHalfResolution;

    uvec2 coord0 = axis == 0u ? uvec2(index0, lineIndex) : uvec2(lineIndex, index0);
    uvec2 coord1 = axis == 0u ? uvec2(index1, lineIndex) : uvec2(lineIndex, index1);

    vec4 value0 = finalInBuffer1 ? fftGroupBuffer1[index0] : fftGroupBuffer0[index0];
    vec4 value1 = finalInBuffer1 ? fftGroupBuffer1[index1] : fftGroupBuffer0[index1];

    outputSpectrumBuffer.outputSpectrumData[spectrumIndex(kFftResolution, cascadeIndex, coord0)] = value0;
    outputSpectrumBuffer.outputSpectrumData[spectrumIndex(kFftResolution, cascadeIndex, coord1)] = value1;
}

void main()
{
    uint resolution = simulation.dispatchParams.x;
    uint cascadeCount = simulation.dispatchParams.y;
    uint cascadeIndex = gl_WorkGroupID.z;
    uint axis = simulation.dispatchParams.w;
    uint lineIndex = gl_WorkGroupID.y;
    uint localIndex = gl_LocalInvocationID.x;

    if (resolution != kFftResolution ||
        cascadeIndex >= cascadeCount ||
        lineIndex >= resolution ||
        localIndex >= kHalfResolution)
    {
        return;
    }

    loadInitialValues(cascadeIndex, axis, lineIndex, localIndex);
    barrier();

    bool writeToBuffer1 = true;
    for (uint step = 0u; step < 9u; ++step)
    {
        fftGroupBuffer1[localIndex] = fftValue(localIndex, false, step);
        fftGroupBuffer1[localIndex + kHalfResolution] = fftValue(localIndex + kHalfResolution, false, step);
        barrier();

        if (step < 8u)
        {
            fftGroupBuffer0[localIndex] = fftValue(localIndex, true, step + 1u);
            fftGroupBuffer0[localIndex + kHalfResolution] = fftValue(localIndex + kHalfResolution, true, step + 1u);
            barrier();
            ++step;
            writeToBuffer1 = false;
        }
        else
        {
            writeToBuffer1 = true;
        }
    }

    storeFinalValues(cascadeIndex, axis, lineIndex, localIndex, writeToBuffer1);
}
