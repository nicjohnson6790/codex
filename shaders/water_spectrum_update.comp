#version 450

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set=0, binding=0, std430) readonly buffer InitialSpectrumBuffer
{
    vec4 initialSpectrumData[];
} initialSpectrumBuffer;

layout(set=1, binding=0, std430) buffer DisplacementSpectrumBuffer
{
    vec4 displacementSpectrumData[];
} displacementSpectrumBuffer;

layout(set=1, binding=1, std430) buffer SlopeSpectrumBuffer
{
    vec4 slopeSpectrumData[];
} slopeSpectrumBuffer;

layout(set=2, binding=0) uniform WaterSimulationUniforms
{
    // Keep this block aligned with QuadtreeWaterMeshRenderer::WaterSimulationUniforms.
    uvec4 dispatchParams;
    vec4 timeAndGlobal;
    vec4 cascadeWorldSizesA;
    vec4 cascadeWorldSizesB;
    vec4 cascadeAmplitudesA;
    vec4 cascadeAmplitudesB;
    vec4 cascadeWindDirXA;
    vec4 cascadeWindDirXB;
    vec4 cascadeWindDirZA;
    vec4 cascadeWindDirZB;
    vec4 cascadeWindSpeedsA;
    vec4 cascadeWindSpeedsB;
    vec4 cascadeFetchesA;
    vec4 cascadeFetchesB;
    vec4 cascadeSpreadBlendA;
    vec4 cascadeSpreadBlendB;
    vec4 cascadeSwellA;
    vec4 cascadeSwellB;
    vec4 cascadePeakEnhancementA;
    vec4 cascadePeakEnhancementB;
    vec4 cascadeShortWavesFadeA;
    vec4 cascadeShortWavesFadeB;
    vec4 cascadeChoppinessA;
    vec4 cascadeChoppinessB;
    vec4 foamParams;
    vec4 foamParams2;
    vec4 simulationParams;
} simulation;

const float kGravity = 9.81;

uint spectrumIndex(uint resolution, uint cascadeIndex, uvec2 coord)
{
    return ((cascadeIndex * resolution + coord.y) * resolution) + coord.x;
}

vec2 complexMultiply(vec2 a, vec2 b)
{
    return vec2(
        a.x * b.x - a.y * b.y,
        a.x * b.y + a.y * b.x);
}

float dispersion(float waveNumber)
{
    float depth = max(simulation.simulationParams.x, 0.01);
    return sqrt(kGravity * waveNumber * tanh(min(waveNumber * depth, 20.0)));
}

void main()
{
    uvec3 gid = gl_GlobalInvocationID.xyz;
    uint resolution = simulation.dispatchParams.x;
    uint cascadeCount = simulation.dispatchParams.y;
    uint cascadeIndex = gid.z;
    if (gid.x >= resolution || gid.y >= resolution || cascadeIndex >= cascadeCount)
    {
        return;
    }

    float timeSeconds = simulation.timeAndGlobal.x;
    float globalLambda = max(simulation.timeAndGlobal.z, 0.01);
    float worldSize = max(
        cascadeIndex < 4u ? simulation.cascadeWorldSizesA[cascadeIndex] : simulation.cascadeWorldSizesB[cascadeIndex - 4u],
        1.0);

    float deltaK = 6.28318530718 / worldSize;
    vec2 centeredIndex = vec2(gid.xy) - vec2(float(resolution) * 0.5);
    vec2 k = centeredIndex * deltaK;

    vec4 initialSpectrum = initialSpectrumBuffer.initialSpectrumData[spectrumIndex(resolution, cascadeIndex, gid.xy)];
    vec2 h0 = initialSpectrum.xy;
    vec2 h0Minus = initialSpectrum.zw;

    float omega = dispersion(length(k));
    float phase = omega * timeSeconds;
    vec2 phaseForward = vec2(cos(phase), sin(phase));
    vec2 phaseBackward = vec2(cos(phase), -sin(phase));
    vec2 heightSpectrum =
        complexMultiply(h0, phaseForward) +
        complexMultiply(vec2(h0Minus.x, -h0Minus.y), phaseBackward);

    float reciprocalWaveNumber = length(k) < 1.0e-5 ? 1.0 : (1.0 / length(k));
    vec2 ih = vec2(-heightSpectrum.y, heightSpectrum.x);
    vec2 displacementX = ih * k.x * reciprocalWaveNumber;
    vec2 displacementY = heightSpectrum;
    vec2 displacementZ = ih * k.y * reciprocalWaveNumber;

    uint index = spectrumIndex(resolution, cascadeIndex, gid.xy);
    displacementSpectrumBuffer.displacementSpectrumData[index] = vec4(displacementX, displacementY);
    slopeSpectrumBuffer.slopeSpectrumData[index] = vec4(displacementZ, 0.0, 0.0);
}
